  static const String server = 'gcr-ws-482782751069.us-central1.run.app';
  static const String token = 'M8b4eFJHq2pI3V9nW5r0dE-PLZpQyX7uB1cTa9kN4mE';
  static final String wsUrl = 'wss://$server?token=$token';

  Timer? _reconnectTimer;
  bool _manuallyClosed = false;

  @override
  void initState() {
    super.initState();
    _connect();
  }

  void _scheduleReconnect() {
    if (_manuallyClosed) return;

    _reconnectTimer?.cancel();
    _reconnectTimer = Timer(const Duration(seconds: 3), () {
      if (!_manuallyClosed) {
        print("🔄 Attempting reconnect...");
        _connect();
      }
    });
  }

  Future<void> _connect() async {
    
    _reconnectTimer?.cancel();
    

    _manuallyClosed = true;

    setState(() {
      statusText = 'Connecting to $wsUrl…';
      connected = false;
    });
    widget.onConnectionChanged?.call(false);

    try {
      socket?.close();
      socket = PiSocket(wsUrl: wsUrl);

      _manuallyClosed = false;

      bool firstMessageReceived = false;

      socket!.events.listen(
        (evt) async {
          if (!firstMessageReceived) {
            firstMessageReceived = true;
            setState(() {
            connected = true;
            statusText = 'Connected';
            print('✅ WebSocket connected successfully!');
            });
            widget.onConnectionChanged?.call(true);
          }
          setState(() {
            lastEventText = evt.fallDetected
                ? '🚨 Fall Detected at ${evt.timestamp}'
                : '✅ No Fall at ${evt.timestamp}';
          });

          final payload = evt.raw['payload'];

          if (payload != null &&
              payload['event'] == 'power_state') {

            final status = payload['status']?.toString() ?? '';

            setState(() {
              if (status.contains('Wall Power')) {
                isWallPower = true;
                powerStatus = 'Wall Power';
              } else if (status.contains('Battery')) {
                isWallPower = false;
                powerStatus = 'Battery Backup';
              }
            });
          }
                   
          if (evt.fallDetected) {
            await FallLogger.logFallEvent(
              source: 'websocket',
              fallDetected: evt.fallDetected,
              timestamp: evt.timestamp,
              extra: evt.raw,
            );
          }
          if (evt.fallDetected) {
            await NotificationService.showManualNotification(
              title: 'Fall Detected!',
              body: 'A fall was detected at ${evt.timestamp}.',
            );
            print('🔔 Notification sent for fall at ${evt.timestamp}');
          }
        },
        onError: (err) {
          setState(() {
            connected = false;
            statusText = 'WebSocket error: $err';
          });
            widget.onConnectionChanged?.call(false);
          print("WebSocket error, scheduling reconnect…");
          _scheduleReconnect();
        },
        onDone: () {
          setState(() {
            connected = false;
            statusText = 'Connection closed';
          });
            widget.onConnectionChanged?.call(false);
          print("WebSocket closed, scheduling reconnect…");
          _scheduleReconnect();
        },
      );

      Future.delayed(const Duration(seconds: 3), () {
      if (!mounted) return;
      if (!firstMessageReceived) {
        setState(() {
          connected = false;
          statusText = 'Failed to connect (timeout)';
        });
          widget.onConnectionChanged?.call(false);
        print("Timeout — scheduling reconnect...");
          _scheduleReconnect();
      }
    });
  } catch (e) {
    setState(() {
      connected = false;
      statusText = 'Error connecting: $e';
    });
      widget.onConnectionChanged?.call(false);
    _scheduleReconnect();
  }
} 
  
  @override
  void dispose() {
    _manuallyClosed = true;
    _reconnectTimer?.cancel();
    _cmdController.dispose();
    socket?.close();
    super.dispose();
  }

  void _sendCustomCommand() {
    if (_formKey.currentState!.validate()) {
      final cmd = _cmdController.text.trim();
      socket?.sendCommand(cmd);
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(content: Text('Sent command: $cmd')),
      );
      _cmdController.clear();
    }
  }

