class PiSocket {
  final String wsUrl;
  late final WebSocketChannel channel;
  Timer? _ping;

  DateTime _parseToDateTime(dynamic ts) {
  // 1) null -> now
  if (ts == null) return DateTime.now();

  // 2) Already DateTime
  if (ts is DateTime) return ts;

  // 3) Numeric -> epoch milliseconds
  if (ts is int) return DateTime.fromMillisecondsSinceEpoch(ts);
  if (ts is double) return DateTime.fromMillisecondsSinceEpoch(ts.toInt());

  // 4) String -> try ISO, epoch string, or custom MM-DD-YYYY HH:MM:SS
  if (ts is String) {
    final trimmed = ts.trim();

    // a) ISO / tryParse
    final iso = DateTime.tryParse(trimmed);
    if (iso != null) return iso;

    // b) numeric string epoch
    final asInt = int.tryParse(trimmed);
    if (asInt != null) return DateTime.fromMillisecondsSinceEpoch(asInt);

    // c) custom MM-DD-YYYY HH:MM:SS
    final custom = _parseMmDdYyyyHms(trimmed);
    if (custom != null) return custom;

    // fallback
    return DateTime.now();
  }

  // unknown -> now
  return DateTime.now();
}

DateTime? _parseMmDdYyyyHms(String s) {
  final regex = RegExp(r'^\s*(\d{1,2})-(\d{1,2})-(\d{4})\s+(\d{1,2}):(\d{1,2})(?::(\d{1,2}))?\s*$');
  final m = regex.firstMatch(s);
  if (m == null) return null;

  final month = int.tryParse(m.group(1)!);
  final day = int.tryParse(m.group(2)!);
  final year = int.tryParse(m.group(3)!);
  final hour = int.tryParse(m.group(4)!) ?? 0;
  final minute = int.tryParse(m.group(5)!) ?? 0;
  final second = m.group(6) != null ? int.tryParse(m.group(6)!) ?? 0 : 0;

  if (year == null || month == null || day == null) return null;

  try {
    return DateTime(year, month, day, hour, minute, second);
  } catch (_) {
    return null;
  }
}

  PiSocket({required this.wsUrl}) {
    channel = WebSocketChannel.connect(Uri.parse(wsUrl));

    // Optional: keep-alive ping every 25s
    _ping = Timer.periodic(const Duration(seconds: 25), (_) {
      channel.sink.add('{"type":"ping"}');
    });
  }

  Stream<FallEvent> get events => channel.stream.map((data) {
  final s = data.toString().trim();
  final jsonString = s.contains("'") ? s.replaceAll("'", '"') : s;
  print("📩 Received from Pi: $jsonString");

  Map<String, dynamic> msg;
  try {
    msg = json.decode(jsonString) as Map<String, dynamic>;
  } catch (e) {
    print("⚠️ JSON decode failed: $e");
    msg = {'payload': {'fall_detected': 0, 'ts': null}, 'raw': s};
  }

  //Extract payload
  final payload = (msg['payload'] is Map)
      ? msg['payload'] as Map<String, dynamic>
      : <String, dynamic>{};

  final fdRaw = payload['fall_detected'];
  final bool fd = fdRaw is bool
      ? fdRaw
      : fdRaw is int
          ? fdRaw == 1
          : fdRaw is String
              ? (fdRaw == '1' || fdRaw.toLowerCase() == 'true')
              : false;
  final rawTs = payload['ts'];

  final DateTime parsedTs = _parseToDateTime(rawTs);
  //final ts = (payload['ts']?.toString().isNotEmpty ?? false)
    //  ? payload['ts'].toString()
    //  : _nowStamp();

  return FallEvent(fallDetected: fd, timestamp: parsedTs, raw: msg);
});

  void sendCommand(String command) => channel.sink.add(command);

  void close() {
    _ping?.cancel();
    channel.sink.close();
  }
}

class FallEvent {
  final bool fallDetected;
  final DateTime timestamp;
  final Map<String, dynamic> raw;
  FallEvent({required this.fallDetected, required this.timestamp, required this.raw});
}



